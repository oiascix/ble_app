<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F1117">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="#1A1D27">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SmartLock"
            android:textColor="#EAEDF5"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnAddLock"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="+ Добавить"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#3D7EFF" />
    </LinearLayout>

    <!-- Статус -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="#1A1D27"
        android:layout_marginTop="1dp">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Инициализация..."
            android:textColor="#8B91A8"
            android:textSize="13sp" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:visibility="gone"
            android:indeterminateTint="#3D7EFF" />
    </LinearLayout>

    <!-- Список замков -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLocks"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:clipToPadding="false"
        android:visibility="gone" />

    <!-- Пустое состояние -->
    <LinearLayout
        android:id="@+id/layoutEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔒"
            android:textSize="64sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Замков пока нет"
            android:textColor="#EAEDF5"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Добавьте замок через QR-код\nили введите данные вручную"
            android:textColor="#8B91A8"
            android:textSize="14sp"
            android:gravity="center" />

        <Button
            android:id="@+id/btnAddLockEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Добавить замок"
            android:textColor="#FFFFFF"
            android:backgroundTint="#3D7EFF" />
    </LinearLayout>

</LinearLayout>